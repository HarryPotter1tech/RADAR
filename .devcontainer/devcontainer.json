{
    "name": "My Dev Container",
    "image": "mcr.microsoft.com/devcontainers/cpp:0-ubuntu-22.04",  // 可根据需要换成自己的镜像或 Dockerfile
    "customizations": {
        "vscode": {
            "extensions": [
                "charliermarsh.ruff",
                "docker.docker",
                "github.copilot-chat",
                "ms-azuretools.vscode-containers",
                "ms-azuretools.vscode-docker",
                "ms-ceintl.vscode-language-pack-zh-hans",
                "ms-python.debugpy",
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.vscode-python-envs",
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cpptools-themes",
                "redhat.vscode-yaml",
                "shd101wyy.markdown-preview-enhanced",
                "twxs.cmake",
                "yzane.markdown-pdf"
            ]
        }
    },
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y git cmake build-essential"  // 按需调整
}